@using MusicLibraryManager.Models 
@model Song

<tr>
	<td>@Model.Title</td>	
	<td>@Model.Artist?.Name</td>
	<td>@Model.Album?.Name</td>
	<td>@Model.Genre</td>
	<td>@Model.ReleaseYear</td>
	<td>
		<div class="table-buttons">
		<a asp-page="Edit" class="btn btn-primary" asp-route-id="@Model.Id">Edit</a>		
		<a asp-page="Details" class="btn btn-secondary" asp-route-id="@Model.Id">Details</a>	
		<a asp-page="Delete" class="btn btn-danger" asp-route-id="@Model.Id">Delete</a>	
		</div>
	</td>
</tr>
